# Main Telegram bot token from @BotFather
BOT_TOKEN=your_main_telegram_bot_token_here

# Second Telegram bot token, used by /dual mode
BOT_TOKEN_2=your_second_telegram_bot_token_here

# Optional single Firecrawl key
FIRECRAWL_API_KEY=fc_your_firecrawl_key_here

# Optional multiple Firecrawl keys. Separate by new lines, spaces, or commas.
FIRECRAWL_KEYS=fc_key_one,fc_key_two

# Optional OpenAI key. If empty, the bot can also read OpenAI keys from r.txt or keyhunter.db.
OPENAI_API_KEY=sk-proj_your_openai_key_here

# Figma Personal Access Token (for /figma command)
FIGMA_TOKEN=figd_your_figma_token_here

# Encryption key for sensitive data at rest (Veo API keys in SQLite).
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a temporary key is generated at runtime (Veo sessions NOT persisted across restarts).
DB_ENCRYPTION_KEY=

# Groq API key — for GPT-OSS-120B text generation (unfiltered, fast, cheap)
GROQ_API_KEY=

# Telegram API ID from my.telegram.org — required for local Bot API server
TELEGRAM_API_ID=your_telegram_api_id_here

# Telegram API hash from my.telegram.org
TELEGRAM_API_HASH=your_telegram_api_hash_here


# Telegram username for payment contact
PAYMENT_USERNAME=your_username

# Password for encrypting API keys file (r.txt.enc).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match across all deployments that share the same r.txt.enc.
KEYS_ENCRYPTION_PASSWORD=

# Optional provider credentials. Keep real values only in .env, never in source control.
MVSEP_API_TOKEN=
UPSCALE_CLIENT_ID=

# Optional provider endpoint/model overrides.
MVSEP_BASE_URL=https://mvsep.com/api
UPSCALE_BASE_URL=https://image-upscaling.net
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-5
# Empty means use OPENROUTER_TEXT_MODEL for image understanding too.
OPENROUTER_VISION_MODEL=
OPENROUTER_APP_TITLE=NanoHatani

# Optional storage/path overrides.
API_KEYS_FILE=/root/Projects/NanoHatani/r.txt
DB_PATH=bot_data.db
KEYHUNTER_DB=/root/RewTest/keyhunter.db
NANO_KEYS_DB=/root/Projects/NanoHatani/nano_keys.db
AGENT_WORKSPACE_BASE=/home/hatani/workspaces
RANDOM_GIF_DIR=media/random_gifs

# Optional provider endpoint/model overrides.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
NVIDIA_IMAGE_BASE_URL=https://ai.api.nvidia.com/v1/genai
NVIDIA_IMAGE_MODEL=black-forest-labs/flux.1-schnell
NVIDIA_VISION_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct
FIRECRAWL_SEARCH_URL=https://api.firecrawl.dev/v2/search
FIRECRAWL_SCRAPE_URL=https://api.firecrawl.dev/v2/scrape
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Docker Compose health-check timings.
TELEGRAM_API_HEALTH_INTERVAL=10s
TELEGRAM_API_HEALTH_TIMEOUT=5s
TELEGRAM_API_HEALTH_RETRIES=5
TELEGRAM_API_HEALTH_START_PERIOD=10s
